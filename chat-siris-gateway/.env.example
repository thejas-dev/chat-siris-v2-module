PORT=8080
SERVICE_NAME=api-gateway

AUTH_SERVICE_URL=http://localhost:3001
# Rollback only — set *_SERVICE_ENABLED=false to restore monolith passthrough for that domain
MONOLITH_URL=http://localhost:3333
AUTH_SERVICE_ENABLED=true
USER_SERVICE_URL=http://localhost:3002
GROUP_SERVICE_URL=http://localhost:3003
MESSAGE_SERVICE_URL=http://localhost:3004
MEDIA_SERVICE_URL=http://localhost:3005
USER_SERVICE_ENABLED=true
GROUP_SERVICE_ENABLED=true
MESSAGE_SERVICE_ENABLED=true
MEDIA_SERVICE_ENABLED=true

REDIS_CACHE_URL=rediss://REPLACE_CACHE.upstash.io:6379
# Local single-instance fallback:
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_DB_CACHE=0

INTERNAL_HMAC_SECRET=change-me-in-production
# During quarterly rotation: set old secret here while gateway signs with INTERNAL_HMAC_SECRET
INTERNAL_HMAC_SECRET_PREVIOUS=

# OpenTelemetry — export to Grafana Tempo or any OTLP HTTP collector
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://tempo.example.com

CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_IP_MAX=100
RATE_LIMIT_USER_MAX=300

# Optional
SENTRY_DSN=
LOG_LEVEL=info
