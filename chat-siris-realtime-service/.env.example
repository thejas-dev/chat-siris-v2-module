PORT=3333
SERVICE_NAME=realtime-service
REDIS_CACHE_URL=rediss://REPLACE_CACHE.upstash.io:6379
REDIS_EVENTS_URL=rediss://REPLACE_EVENTS.upstash.io:6379
# Local single-instance fallback:
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_DB_CACHE=0
# REDIS_DB_EVENTS=1
JWT_PUBLIC_KEY=
SOCKET_AUTH_REQUIRED=true
GROUP_SERVICE_URL=http://localhost:3003
INTERNAL_HMAC_SECRET=change-me
CORS_ORIGINS=http://localhost:3000,https://*.vercel.app
# Set true for local dev (hot reload + multiple tabs exceed limits quickly)
CONNECT_RATE_LIMIT_DISABLED=false
CONNECT_RATE_LIMIT_MAX=20
CONNECT_RATE_LIMIT_WINDOW_SEC=300
