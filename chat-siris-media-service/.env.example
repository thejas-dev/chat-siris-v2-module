PORT=3005
SERVICE_NAME=media-service

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=chat_media

REDIS_CACHE_URL=rediss://REPLACE_CACHE.upstash.io:6379
REDIS_EVENTS_URL=rediss://REPLACE_EVENTS.upstash.io:6379
# Local single-instance fallback:
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_DB_CACHE=0
# REDIS_DB_EVENTS=1

INTERNAL_HMAC_SECRET=change-me-in-production

# Copy exactly from ImageKit dashboard (public keys end with =)
IMAGEKIT_PUBLIC_KEY=public_your_key=
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

LOG_LEVEL=info
